{
  "name": "play-nepal",
  "version": "0.1.0",
  "private": true,
  "description": "Play Nepal — Nepal's largest multiplayer gaming platform",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@play-nepal/server & npm run dev --workspace=@play-nepal/web",
    "dev:server": "npm run dev --workspace=@play-nepal/server",
    "dev:web": "npm run dev --workspace=@play-nepal/web",
    "build": "npm run build --workspace=@play-nepal/shared && npm run build --workspace=@play-nepal/server && npm run build --workspace=@play-nepal/web",
    "build:shared": "npm run build --workspace=@play-nepal/shared",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace=@play-nepal/server",
    "prisma:migrate": "npm run prisma:migrate --workspace=@play-nepal/server",
    "prisma:seed": "npm run prisma:seed --workspace=@play-nepal/server",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "allowScripts": {
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true,
    "esbuild@0.25.12": true,
    "prisma@5.22.0": true
  }
}
