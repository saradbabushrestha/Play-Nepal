# ─────────────────────────────────────────────────────────────
# Play Nepal — environment template. Copy to .env and fill in.
# ─────────────────────────────────────────────────────────────

# --- Core ---
NODE_ENV=development
SERVER_PORT=4000
WEB_ORIGIN=http://localhost:5173

# --- Database (Postgres) ---
# Local dev via docker compose uses port 5435 to avoid clashing with a host Postgres.
DATABASE_URL=postgresql://playnepal:playnepal@localhost:5435/playnepal?schema=public

# --- Redis (socket scaling / pub-sub / rate limit store) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# --- Frontend (Vite) — must be prefixed with VITE_ ---
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
VITE_GOOGLE_CLIENT_ID=
